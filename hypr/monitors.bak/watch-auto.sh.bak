#!/bin/bash

SOCKET="$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock"
SELECTOR="$HOME/.config/hypr/monitors/select.sh"
RESTORE="$HOME/.config/hypr/monitors/profiles/restore-laptop.sh"
STATE_FILE="$HOME/.config/hypr/monitors/.last-mode"
IGNORE_FILE="/tmp/hypr-ignore-monitor-removes"
LOCKFILE="/tmp/hypr-monitor-menu.lock"
LOGFILE="/tmp/hypr-watch-auto.log"

[ ! -S "$SOCKET" ] && {
    echo "Socket not found: $SOCKET" >&2
    exit 1
}

touch "$IGNORE_FILE"

is_ignored_remove() {
    local mon="$1"
    grep -qx "$mon" "$IGNORE_FILE"
}

consume_ignored_remove() {
    local mon="$1"
    grep -vx "$mon" "$IGNORE_FILE" > "${IGNORE_FILE}.tmp"
    mv "${IGNORE_FILE}.tmp" "$IGNORE_FILE"
}

is_internal_monitor() {
    [[ "$1" =~ ^(eDP|LVDS) ]]
}

is_real_external_monitor() {
    [[ "$1" =~ ^(HDMI|DP|DVI|VGA)- ]] || [[ "$1" =~ ^DP-[0-9] ]] || [[ "$1" =~ ^HDMI-A-[0-9]$ ]]
}

launch_selector() {
    if [ -f "$LOCKFILE" ]; then
        echo "$(date '+%H:%M:%S') selector skipped (lock active)" >> "$LOGFILE"
        return
    fi

    touch "$LOCKFILE"
    (
        sleep 1
        "$SELECTOR"
        rm -f "$LOCKFILE"
    ) </dev/null >/dev/null 2>>"$LOGFILE" &
}

restore_if_needed() {
    if [ -f "$STATE_FILE" ] && grep -qx "monitor-only" "$STATE_FILE"; then
        echo "$(date '+%H:%M:%S') restoring laptop display" >> "$LOGFILE"
        "$RESTORE" >/dev/null 2>>"$LOGFILE"
        echo "primary-only" > "$STATE_FILE"
    else
        echo "$(date '+%H:%M:%S') no restore needed" >> "$LOGFILE"
    fi
}

echo "started $(date)" > "$LOGFILE"

socat -U - UNIX-CONNECT:"$SOCKET" | while IFS= read -r line; do
    case "$line" in
        'monitoradded>>'*)
            mon="${line#monitoradded>>}"

            if is_internal_monitor "$mon"; then
                continue
            fi

            if ! is_real_external_monitor "$mon"; then
                echo "$(date '+%H:%M:%S') ignored non-external add: $mon" >> "$LOGFILE"
                continue
            fi

            echo "$(date '+%H:%M:%S') external connected: $mon" >> "$LOGFILE"
            launch_selector
            ;;

        'monitorremoved>>'*)
            mon="${line#monitorremoved>>}"

            if is_internal_monitor "$mon"; then
                continue
            fi

            if ! is_real_external_monitor "$mon"; then
                echo "$(date '+%H:%M:%S') ignored non-external remove: $mon" >> "$LOGFILE"
                continue
            fi

            if is_ignored_remove "$mon"; then
                echo "$(date '+%H:%M:%S') ignored scripted remove: $mon" >> "$LOGFILE"
                consume_ignored_remove "$mon"
                continue
            fi

            echo "$(date '+%H:%M:%S') external removed: $mon" >> "$LOGFILE"
            restore_if_needed
            ;;
    esac
done